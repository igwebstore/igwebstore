10 REM THIS PROGRAM WORKS OUT STATISTICS BASED ON THE SAMPLING DISTRIBUTION (GENERATED BY MONTE CARLO METHOD) FOR THE DIFFERENCE BETWEEN TWO IRs [IR = Identification Ratio; Pass ratio = 1-IR]
20 REM IT ALSO PROVIDES CONFIDENCE INTERVALS FOR THE INDIVIDUAL SAMPLES
30 REM THE CRUCIAL TWO-TAILED SIGNIFICANCE TEST IS FOUND IN BOTTOM RIGHT HAND CORNER OF EACH OF THE THREE ITERATIONS
40 REM ONE-TAILED MAY BE GOOD ENOUGH AND CAN BE FOUND IN THE MIDDLE OF THE BOTTOM LINE
50
60 REM NEXT TWO LINES INSTALL SORT LIBRARY
70 INSTALL @lib$+"SORTLIB"
80 sort% = FN_sortinit(0,0)
90
100 REM NUMBER OF PAIRS OF SAMPLES DRAWN AT RANDOM FOR THE MONTE CARLO SIMULATION
110 INPUT "How many iterations for the Monte Carlo simulation (default is 10000)" ;ZZZ
120 IF ZZZ = 0 THEN
130   ZZZ = 10000
140 ENDIF
150
160 REM IS THIS JUST TESTING OR FOR PUBLICATION?
170 PRINT
180 PRINT "PROGRAM ALWAYS RUNS THREE ITERATIONS AND THEN ASKS FOR NEXT INPUT. ASKS: USE FOR EG PUBLICATION, OR TESTING?"
190 INPUT "STORE OUTPUT IN AN (EXISTING)TEXT FILE AND RUN 30,000 TRIALS (= '1') (OR TESTING = Default)" ;Store
200 IF Store = 1 THEN
210   INPUT "GIVE FULL PATHNAME FOR RESULTS FILE (Default is C:\Harry\imgame\results.txt)";SPOOLFILE$
220   IF SPOOLFILE$ = "" THEN
230     SPOOLFILE$ = "SPOOLON C:\Harry\imgame\results.txt"
240     ZZZ=30000
250   ELSE SPOOLFILE$="SPOOLON "+SPOOLFILE$
260   ENDIF
270   OSCLI SPOOLFILE$
280 ENDIF
290
300 REM OUTER-OUTER LOOP: ALLOWS 10 ITERATIONS OF DATA ENTRY
310 FOR w = 1 TO 10
320
330   REM INPUT DATA
340   INPUT "1st Sample: How many Whites";WS;
350   INPUT "How many Greys";GS;
360   INPUT "How many Blacks";BS;
370
380   INPUT "2nd SAMPLE: How many Whites";WS2;
390   INPUT "How many Greys";GS2;
400   INPUT "How many Blacks";BS2;
410
420   ZERO1 = 0
430   IF WS > BS THEN
440     INPUT "WOULD YOU LIKE TO SET NEGATIVE IR IN SAMPLE 1 TO ZERO (1) IF 'yes': white and black -> (white+black)/2" ZERO1
450   ENDIF
460   IF ZERO1 = 1 THEN
470     WS = (WS + BS)/2
480     BS = WS
490   ENDIF
500
510   ZERO2 = 0
520   IF WS2 > BS2 THEN
530     INPUT "WOULD YOU LIKE TO SET NEGATIVE IR IN SAMPLE 2 TO ZERO (1) IF 'yes': white and black -> (white+black)/2" ZERO2
540   ENDIF
550   IF ZERO2 = 1 THEN
560     WS2 = (WS2 + BS2)/2
570     BS2 = WS2
580   ENDIF
590
600   REM SAMPLE SIZES
610   SS = WS+GS+BS
620   SS2 = WS2+GS2+BS2
630   ST = SS+SS2
640
650   REM IRS OF THE SAMPLE
660   Sir=(BS-WS)/SS
670   Sir2=(BS2-WS2)/SS2
680   REM Difference between the two IRs
690   Adiff = ABS(Sir2-Sir)
700
710   REM Calculates SD of first and second samples for input into t-test, eg, http://www.quantitativeskills.com/sisa/statistics/t-test.htm
720   SDS1 = ((WS*((Sir+1)^2) + GS*((Sir)^2) + BS*((Sir-1)^2))/SS)^.5
730   SDS2 = ((WS2*((Sir2+1)^2) + GS2*((Sir2)^2) + BS2*((Sir2-1)^2))/SS2)^.5
740
750   PRINT
760   PRINT "THE SD's, SS's AND IR's BELOW COULD BE PLUGGED INTO A T-TEST EG http://www.quantitativeskills.com/sisa/statistics/t-test.htm"
770   PRINT
780   PRINT "SAMPLE1: ";WS;"W+";GS;"G+";BS;"B=";SS;" ";TAB(35) "IR/PR = ";Sir;" / ";(1-Sir) ;TAB(90)"{StDev} = ";SDS1
790   PRINT "SAMPLE2: ";WS2;"W+";GS2;"G+";BS2;"B=";SS2;" ";TAB(35) "IR/PR = "; Sir2;" / ";(1-Sir2);TAB(70)"DIFF=";Adiff;TAB(90)"{StDev} = ";SDS2
800   PRINT
810   PRINT "NO OF RANDOM SAMPLES IN EACH SIMULATION IS ";ZZZ;"       NOW WAIT FOR THE RESULT WHICH WILL BE ITERATED 3 TIMES"
820   PRINT "==============================================================================================================="
830
840   DIM DiffIR(ZZZ)
850   DIM IRindA(ZZZ)
860   DIM IRindB(ZZZ)
870
880   REM THERE ARE SOME MINOR REDUNDANCIES IN THIS PROGRAM BUT REMOVING THEM WOULD MEAN RENUMBERING THE ROUNDING LIST AND IT IS EASIER TO LEAVE THEM
890
900   REM OUTER LOOP: ITERATES 3 TIMES FROM HERE ON
910   FOR m = 1 TO 3
920
930     BiggerABS = 0
940     SQD = 0
950     CumSQD=0
960     RDiff=0
970
980     REM NON-AVERAGED WEIGHTS FOR INDIVIDUAL SAMPLES
990     WhiteA=WS/SS
1000     GreyA=GS/SS
1010     BlackA=BS/SS
1020     WhiteB=WS2/SS2
1030     GreyB=GS2/SS2
1040     BlackB=BS2/SS2
1050
1060     REM GIVES AVERAGED WEIGHTINGS TO WHITE, GREY AND BLACK
1070     WhiteWeight = (WS+WS2)/ST
1080     GreyWeight = (GS+GS2)/ST
1090     BlackWeight = (BS+BS2)/ST
1100
1110     REM MAIN LOOP: ITERATES ZZZ TIMES FROM HERE ON
1120
1130     FOR o = 1 TO ZZZ
1140       WA=0:GA=0:BA=0
1150       WB=0:GB=0:BB=0
1160       GAC=0:BAC=0
1170       GBC=0:BBC=0
1180       WAind=0:GAind=0:BAind=0
1190       WBind=0:GBind=0:BBind=0
1200
1210       REM ZEROTH INNER LOOP: CREATES ARRAYS OF RANDOMLY GENERATED IRs FOR INDIVIDUAL SAMPLES WITH OWN INDIVIDUAL WEIGHTS
1220       FOR n=1 TO SS
1230         x=RND(1)
1240         IF x =< WhiteA THEN WAind=WAind+1
1250         IF x =< (WhiteA+GreyA) THEN GAind=GAind+1
1260       NEXT n
1270       BAind = SS-GAind
1280       GAind = GAind - WAind
1290       IRindA(o)=(BAind-WAind)/SS
1300
1310       FOR n=1 TO SS2
1320         x=RND(1)
1330         IF x =< WhiteB THEN WBind=WBind+1
1340         IF x =< (WhiteB+GreyB) THEN GBind=GBind+1
1350       NEXT n
1360       BBind = SS2-GBind
1370       GBind = GBind - WBind
1380       IRindB(o)=(BBind-WBind)/SS2
1390
1400       REM FIRST INNER LOOP: ITERATES FOR FIRST SAMPLE SIZE TO CREATE RANDOM SAMPLE A FROM AVERAGED WEIGHTS
1410       FOR n=1 TO SS
1420         x=RND(1)
1430         IF x =< WhiteWeight THEN WA=WA+1
1440         IF x =< (WhiteWeight+GreyWeight) THEN GA=GA+1
1450       NEXT n
1460       BA = SS-GA
1470       GA = GA - WA
1480
1490       REM SECOND INNER LOOP: ITERATES FOR SECOND SAMPLE SIZE TO CREATE RANDOM SAMPLE B FROM AVERAGED WEIGHTS
1500       FOR n=1 TO SS2
1510         x=RND(1)
1520         IF x =< WhiteWeight THEN WB=WB+1
1530         IF x =< (WhiteWeight+GreyWeight) THEN GB=GB+1
1540       NEXT n
1550       BB = SS2-GB
1560       GB = GB - WB
1570
1580       REM END OF INNER LOOPS AND BACK TO MAIN LOOP
1590
1600       REM IRs OF EACH PAIR OF RANDOMLY GENERATED SAMPLES
1610       irA = (BA-WA)/SS
1620       irB = (BB-WB)/SS2
1630
1640       RDiffABS=ABS(irB-irA)
1650
1660       REM CREATING ARRAY AND COMPONENTS OF STANDARD DEVIATION
1670       DiffIR(o) = RDiffABS
1680       SQD = (DiffIR(o))^2
1690       CumSQD = CumSQD+SQD
1700
1710       IF RDiffABS => Adiff THEN
1720         BiggerABS = BiggerABS +1
1730       ENDIF
1740
1750     NEXT o
1760     REM END OF MAIN LOOP (ZZZ random samples or pairs of samples) AND BACK TO OUTER LOOP
1770
1780     REM SD=STANDARD DEVIATION
1790     SD = (CumSQD/ZZZ)^0.5
1800
1810     REM PROPORTIONS OF DIFFERENCES BETWEEN PAIRS THAT ARE BIGGER THAN THE ACTUAL DIFFERENCE
1820
1830     REM SORTS THE ARRAYS
1840     C%=ZZZ
1850     CALL sort%,DiffIR(1)
1860     CALL sort%,IRindA(1)
1870     CALL sort%,IRindB(1)
1880
1890     DIM X(50)
1900     DIM XR(50)
1910     DIM A%(50)
1920
1930     REM PREPARES RESULTS BASED ON POSITION IN THE ARRAY AND MEAN OF DISTRIBUTION PLUS AND MINUS NUMBERS OF SDs; ALL THESE ARE SENT FOR ROUNDING
1940     REM QUITE A FEW OF THESE LINES ARE REDUNDANT BUT SAVES RENUMBERING LIST
1950     X(1)=Adiff+((DiffIR(((ZZZ*2.5/100)+1))))
1960     X(2)=Adiff+(DiffIR(((ZZZ*97.5/100))))
1970     X(3)=Adiff+((DiffIR(((ZZZ*0.5/100)+1))))
1980     X(4)=Adiff+(DiffIR(((ZZZ*99.5/100))))
1990     X(5)=Adiff-(SD*1.96)
2000     X(6)=Adiff+(SD*1.96)
2010     X(7)=Adiff-(SD*2.575)
2020     X(8)=Adiff+(SD*2.575)
2030     X(9)=0
2040     X(10)=0
2050     X(11)=0
2060     X(12)=SD
2070     X(13)=0
2080     X(14)=0
2090     X(15)=SDS1
2100     X(16)=SDS2
2110     X(17)=Adiff
2120     X(18)=Sir
2130     X(19)=Sir2
2140     X(20)=IRindA(((ZZZ*2.5/100)+1))
2150     X(21)=IRindA(((ZZZ*97.5/100)))
2160     X(22)=IRindA(((ZZZ*0.5/100)+1))
2170     X(23)=IRindA(((ZZZ*99.5/100)))
2180     X(24)=IRindB(((ZZZ*2.5/100)+1))
2190     X(25)=IRindB(((ZZZ*97.5/100)))
2200     X(26)=IRindB(((ZZZ*0.5/100)+1))
2210     X(27)=IRindB(((ZZZ*99.5/100)))
2220
2230     REM Rounding to 4 decimal places
2240     X(28)=BiggerABS/ZZZ
2250     A%(28) = (X(28)+0.00005)*10000
2260     XR(28)=A%(28)/10000
2270
2280     REM SENDS X(1) TO X(27) TO 2-DECIMAL-PLACE ROUNDING PROCEDURE LOCATED AFTER 'END' OF PROGRAM WHICH CONVERTS THEM TO XR(n)s
2290     PROC_ROUND
2300
2310     REM PRINTS DESCRIPTIVE STATISTICS AND ROUNDED VERSIONS [XR] OF SOME OF X(1) TO X(27)
2320     PRINT "CONFIDENCE INTERVALS: Sample1 95%: ";XR(20);"<>";XR(21);"; 99%: ";XR(22);"<>";XR(23);
2330     PRINT ;" --- Sample2 95%: ";XR(24);"<>";XR(25);"; 99%: ";XR(26);"<>";XR(27)
2340     PRINT
2350     PRINT ;"DIFF BETWEEN 2 IRs: "; TAB(25) "CONFIDENCE INTERVALS: 95%: ";XR(1);"<>";XR(2)"    99%: ";XR(3)"<>";XR(4)
2360     PRINT
2370     PRINT "Sample2-sample1 Monte Carlo/Bootstrap Stan Dev = ";X(12);";       one tailed =";XR(28)/2;";      two-tailed = "XR(28)
2380     PRINT "==============================================================================================================="
2390
2400   NEXT m
2410   REM END OF OUTER LOOP -- 3 ITERATIONS
2420 NEXT w
2430 REM END OF OUTER-OUTER LOOP -- ALLOWS 10 REPETITIONS OF DATA ENTRY
2440 END
2450
2460 REM ROUNDING PROCEDURE
2470 DEF PROC_ROUND
2480 ADD = .005
2490 FOR q = 1 TO 27
2500   IF X(q) < 0 THEN
2510     ADD = -.005
2520   ENDIF
2530   A%(q) = (X(q)+ADD)*100
2540   XR(q)=A%(q)/100
2550 NEXT q
2560 ENDPROC